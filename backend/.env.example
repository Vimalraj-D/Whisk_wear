PORT=5000

# Frontend URL(s) for CORS (comma-separated for multiple)
FRONTEND_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin
ADMIN_SECRET=generate-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=bcrypt-hash-of-admin-password
# MUST be a strong random string (>= 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=your-admin-jwt-secret-here
USER_JWT_SECRET=your-user-jwt-secret-here

# Supabase S3 Storage
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-southeast-1
SUPABASE_S3_BUCKET=Images
SUPABASE_S3_ACCESS_KEY=your-s3-access-key
SUPABASE_S3_SECRET_KEY=your-s3-secret-key
SUPABASE_PROJECT_ID=your-project-id

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Email (Nodemailer via Gmail or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=WhiskWear <your-email@gmail.com>
